# Agent daemon defaults for a remote host that uploads sessions to the viewer.
#
# Copy this file to `.env` on the daemon host:
#   cp .env.agent.example .env
#
# The `start-agent-daemon.sh` wrapper forces remote sync mode, so this file only
# includes the values the daemon actually needs in normal use.

CODEX_VIEWER_SERVER_URL=http://127.0.0.1:8000
CODEX_VIEWER_SYNC_API_TOKEN=replace-with-managed-token-from-/settings

# Optional agent overrides:
# CODEX_VIEWER_SOURCE_HOST=my-hostname
# CODEX_SESSION_ROOTS=~/.codex/sessions
# CODEX_VIEWER_SYNC_INTERVAL=30
# CODEX_VIEWER_LOG_LEVEL=info
