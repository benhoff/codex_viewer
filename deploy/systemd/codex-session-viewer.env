# Adjust these values for the target machine before enabling the units.

CODEX_VIEWER_HOST=0.0.0.0
CODEX_VIEWER_PORT=8000
CODEX_VIEWER_LOG_LEVEL=info
# Keep reload disabled under systemd unless you are intentionally debugging code
# on the target machine.
CODEX_VIEWER_SERVER_DEV_RELOAD=0
CODEX_VIEWER_SERVER_DEV_RELOAD_INTERVAL=1
CODEX_VIEWER_AGENT_DEV_RELOAD=0
CODEX_VIEWER_AGENT_DEV_RELOAD_INTERVAL=1
CODEX_VIEWER_SOURCE_HOST=nanopct6-lts

# The server owns SQLite. Agents should use `remote`; a single-box install can still use `local`.
CODEX_VIEWER_SYNC_MODE=remote
CODEX_VIEWER_SERVER_URL=http://127.0.0.1:8000
# Set this on daemon hosts to a managed token created in /settings.
CODEX_VIEWER_SYNC_API_TOKEN=change-me
CODEX_VIEWER_REMOTE_TIMEOUT=15
# Optional: local command the agent runs when the server advertises a different agent version.
# CODEX_VIEWER_AGENT_UPDATE_COMMAND=/home/wulfuser/codex_viewer/scripts/update-agent.sh

# Comma-separated rollout roots to scan.
CODEX_SESSION_ROOTS=/home/wulfuser/.codex/sessions

# SQLite location for the normalized viewer database.
CODEX_VIEWER_DB=/home/wulfuser/codex_viewer/data/codex_sessions.sqlite3
CODEX_VIEWER_DATA_DIR=/home/wulfuser/codex_viewer/data

# Background sync cadence in seconds.
CODEX_VIEWER_SYNC_INTERVAL=30

# Set to 1 if the daemon should rebuild the full index on startup.
CODEX_VIEWER_DAEMON_REBUILD_ON_START=0
