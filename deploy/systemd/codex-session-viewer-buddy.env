# Separate viewer instance for buddy/ingest testing.
# This server is isolated from the main instance by code path, data dir, port,
# auth bootstrap, and sync token database.

CODEX_VIEWER_HOST=0.0.0.0
CODEX_VIEWER_PORT=8002
CODEX_VIEWER_LOG_LEVEL=info
CODEX_VIEWER_AUTH_MODE=password
CODEX_VIEWER_SERVER_DEV_RELOAD=0
CODEX_VIEWER_SERVER_DEV_RELOAD_INTERVAL=1
CODEX_VIEWER_SOURCE_HOST=arch-buddy

# This instance is intended to receive remote uploads from a separate machine.
CODEX_VIEWER_SYNC_MODE=remote
CODEX_VIEWER_SERVER_URL=http://192.168.1.125:8002
CODEX_VIEWER_REMOTE_TIMEOUT=15

# Point at an isolated empty directory so this instance never scans local
# rollout directories, even if a daemon is started later by mistake.
CODEX_SESSION_ROOTS=/opt/codex_viewer_buddy/session_roots

# Isolated SQLite/database state for the buddy instance.
CODEX_VIEWER_DB=/opt/codex_viewer_buddy/data/codex_sessions.sqlite3
CODEX_VIEWER_DATA_DIR=/opt/codex_viewer_buddy/data

# Setup creates API tokens in-app; place the raw token on the remote client
# machine after the first admin login.
CODEX_VIEWER_SYNC_API_TOKEN=

# Included for consistency with the main deployment; the server service itself
# does not poll for remote uploads.
CODEX_VIEWER_SYNC_INTERVAL=30
CODEX_VIEWER_DAEMON_REBUILD_ON_START=0
