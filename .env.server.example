# Server defaults for running the viewer locally without systemd.
#
# Copy this file to `.env` on the server host:
#   cp .env.server.example .env

CODEX_VIEWER_DATA_DIR=./data
CODEX_VIEWER_HOST=127.0.0.1
CODEX_VIEWER_PORT=8000
CODEX_VIEWER_SYNC_MODE=remote

# Optional server logging override:
# CODEX_VIEWER_LOG_LEVEL=info

# Browser auth defaults to password.
CODEX_VIEWER_AUTH_MODE=password
# The viewer will generate and persist a session secret in ./data/.session-secret.
# Then open /setup once to create the first local admin.

# Explicit opt-out for a trusted localhost-only install:
# CODEX_VIEWER_AUTH_MODE=none

# Optional reverse-proxy SSO:
# CODEX_VIEWER_AUTH_MODE=proxy
# Optional override if you do not want the generated secret file:
# CODEX_VIEWER_SESSION_SECRET=replace-with-a-long-random-secret
# CODEX_VIEWER_AUTH_PROXY_USER_HEADER=X-Forwarded-User
# CODEX_VIEWER_AUTH_PROXY_NAME_HEADER=X-Forwarded-Name
# CODEX_VIEWER_AUTH_PROXY_EMAIL_HEADER=X-Forwarded-Email
# CODEX_VIEWER_AUTH_PROXY_LOGIN_URL=https://sso.example.com
# CODEX_VIEWER_AUTH_PROXY_LOGOUT_URL=https://sso.example.com/logout
# CODEX_VIEWER_AUTH_COOKIE_SECURE=1
#
# Concrete examples live in deploy/proxy/
#
# Caddy + Authentik keeps the default viewer headers:
# CODEX_VIEWER_AUTH_MODE=proxy
# CODEX_VIEWER_AUTH_PROXY_USER_HEADER=X-Forwarded-User
# CODEX_VIEWER_AUTH_PROXY_NAME_HEADER=X-Forwarded-Name
# CODEX_VIEWER_AUTH_PROXY_EMAIL_HEADER=X-Forwarded-Email
#
# Traefik + Authelia uses Remote-* headers instead:
# CODEX_VIEWER_AUTH_MODE=proxy
# CODEX_VIEWER_AUTH_PROXY_USER_HEADER=Remote-User
# CODEX_VIEWER_AUTH_PROXY_NAME_HEADER=Remote-Name
# CODEX_VIEWER_AUTH_PROXY_EMAIL_HEADER=Remote-Email
