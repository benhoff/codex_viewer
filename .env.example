# Copy this file to .env for local runs outside systemd.

CODEX_VIEWER_ENV=local
CODEX_VIEWER_SYNC_MODE=local
CODEX_SESSION_ROOTS=~/.codex/sessions
CODEX_VIEWER_DATA_DIR=./data
CODEX_VIEWER_DB=./data/codex_sessions.sqlite3
CODEX_VIEWER_HOST=127.0.0.1
CODEX_VIEWER_PORT=8000
CODEX_VIEWER_SYNC_ON_START=1
CODEX_VIEWER_SYNC_INTERVAL=30
CODEX_VIEWER_LOG_LEVEL=info
CODEX_VIEWER_PAGE_SIZE=24
CODEX_VIEWER_REMOTE_TIMEOUT=15
CODEX_VIEWER_API_VERSION=1
CODEX_VIEWER_APP_VERSION=0.1.0
CODEX_VIEWER_EXPECTED_AGENT_VERSION=0.1.0
CODEX_VIEWER_MIN_AGENT_VERSION=0.1.0

# Remote sync example:
# CODEX_VIEWER_SYNC_MODE=remote
# CODEX_VIEWER_SERVER_URL=http://127.0.0.1:8000
# CODEX_VIEWER_SYNC_API_TOKEN=change-me
# CODEX_VIEWER_SOURCE_HOST=my-laptop

# Optional daemon behavior:
# CODEX_VIEWER_DAEMON_REBUILD_ON_START=1
# CODEX_VIEWER_AGENT_UPDATE_COMMAND=/path/to/update-agent.sh

# Optional local wrapper behavior:
# CODEX_VIEWER_DEV_RELOAD=1
# CODEX_VIEWER_DEV_RELOAD_INTERVAL=1
