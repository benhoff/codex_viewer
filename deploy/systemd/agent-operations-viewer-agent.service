[Unit]
Description=Agent Operations Viewer agent daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hoff
Group=hoff
WorkingDirectory=/home/hoff/agent_operations_viewer
EnvironmentFile=-/home/hoff/agent_operations_viewer/deploy/systemd/agent-operations-viewer.env
ExecStart=/home/hoff/agent_operations_viewer/scripts/start-agent-daemon.sh
Restart=on-failure
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
