# Development defaults for working on this repo locally.
#
# Copy this file to `.env` when you want to run the repo's server and daemon
# wrappers with dev reload enabled:
#   cp .env.development.example .env

CODEX_VIEWER_ENV=development
CODEX_VIEWER_DATA_DIR=./data
CODEX_VIEWER_HOST=127.0.0.1
CODEX_VIEWER_PORT=8000
CODEX_VIEWER_SERVER_URL=http://127.0.0.1:8000
CODEX_VIEWER_SYNC_API_TOKEN=replace-with-managed-token-from-/settings
CODEX_VIEWER_SERVER_DEV_RELOAD=1
CODEX_VIEWER_SERVER_DEV_RELOAD_INTERVAL=1
CODEX_VIEWER_AGENT_DEV_RELOAD=1
CODEX_VIEWER_AGENT_DEV_RELOAD_INTERVAL=1

# Optional development overrides:
# CODEX_VIEWER_SOURCE_HOST=dev-machine
# CODEX_SESSION_ROOTS=~/.codex/sessions
# CODEX_VIEWER_SYNC_INTERVAL=30
# CODEX_VIEWER_LOG_LEVEL=info

# Optional local auth while developing:
# CODEX_VIEWER_AUTH_MODE=password
# The viewer will generate and persist a session secret in ./data/.session-secret.
# Then open /setup once to create the first local admin.
